{
  "name": "little-guy",
  "version": "1.0.0",
  "description": "Interactive desktop buddy that reacts to your live desktop activity",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.qrytics.littleguy",
    "productName": "littleGuy",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron": "^35.7.5"
  },
  "devDependencies": {
    "electron-builder": "^26.0.0"
  }
}
