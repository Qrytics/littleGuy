{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "littleGuy",
  "version": "2.0.0",
  "identifier": "com.qrytics.littleguy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "littleGuy",
        "width": 80,
        "height": 160,
        "x": 100,
        "y": 100,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "url": "index.html"
      },
      {
        "label": "recap",
        "title": "Daily Recap – littleGuy",
        "width": 600,
        "height": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "url": "recap.html"
      },
      {
        "label": "minigame",
        "title": "Whack-a-Guy",
        "width": 400,
        "height": 360,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "url": "minigame.html"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {}
    },
    "linux": {
      "appimage": {}
    },
    "macOS": {
      "dmg": {}
    }
  }
}
